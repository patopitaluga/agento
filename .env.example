OPENAI_API_KEY=..
WORKSPACE_DIR=generated
# Optional path to personal agent context (default: agent-context.md in project root)
# AGENT_CONTEXT_PATH=agent-context.md
# Optional speech dictionary for transcription and agent disambiguation (default: dictionary.md)
# DICTIONARY_PATH=dictionary.md
# Browser speech preview while recording (set false to disable)
SPEECH_PREVIEW=false
# Built-in file tools: full (default) or readonly (read_file and list_files only)
# TOOL_PROFILE=readonly
# Optional comma-separated override to disable specific tools (built-in or plugin)
# DISABLED_TOOLS=write_file,delete_file
