{
  "name": "agento",
  "version": "1.0.0",
  "description": "Hands-free agent. Speak or type to an agent that actually does the work — documentation, planning, recipes, file operations — or snap a handwritten diagram and let it build the files. Customize its workspace and context to fit whatever you're working on.",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "electron .",
    "server": "if [ -f .env ]; then node --env-file=.env server.ts; else node server.ts; fi",
    "test": "node --test test/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=24.7.0",
    "npm": ">=11.5.1"
  },
  "type": "module",
  "dependencies": {
    "@openai/agents": "^0.11.8",
    "cookie": "^0.7.2",
    "cookie-parser": "^1.4.7",
    "csrf": "^3.1.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.62.0",
    "electron": "^42.4.1",
    "eslint": "^9.39.2"
  }
}
